{
  "sector": "local_service",
  "display_name": "Local Services (Plumber, Electrician, Cleaning, AC Repair, etc.)",
  "channels": [
    {"name": "google_ads", "priority": 1, "reason": "'plumber near me' and service-specific searches are highest intent"},
    {"name": "google_business", "priority": 2, "posts_per_week": 2, "reason": "Local pack listing and reviews are critical"},
    {"name": "whatsapp", "priority": 3, "messages_per_week": 1, "reason": "Booking confirmations and seasonal reminders"},
    {"name": "instagram", "priority": 4, "posts_per_week": 2, "reason": "Work photos and customer reviews build trust"},
    {"name": "facebook", "priority": 5, "reason": "Community groups and local recommendations"}
  ],
  "content_types": ["post", "campaign_message", "gmb_post"],
  "posting_schedule": {
    "monday": {"channel": "google_business", "type": "gmb_post", "topic": "Service highlight / availability update"},
    "wednesday": {"channel": "instagram", "type": "post", "topic": "Completed job photo / before-after"},
    "friday": {"channel": "instagram", "type": "post", "topic": "Customer testimonial / review screenshot"},
