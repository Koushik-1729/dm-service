  "festivals": [
    {"name": "Pre-Diwali", "month": 10, "campaign": "Diwali deep cleaning packages"},
    {"name": "Monsoon", "month": 7, "campaign": "Monsoon plumbing/electrical checkup"},
    {"name": "Summer", "month": 4, "campaign": "AC servicing — book early"},
    {"name": "Pre-Wedding Season", "month": 11, "campaign": "Home renovation and painting services"}
  ],
  "compliance": {
