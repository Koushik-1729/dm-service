ENV=local
PROJECT_NAME=marketing-service
DEBUG=true

# Database (Supabase or local PostgreSQL)
DB_URL=postgresql+psycopg://postgres:postgres@localhost:5432/marketing
DB_SCHEMA=marketing

# Redis (for task queue — Phase 2)
REDIS_URL=redis://localhost:6379

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_VERIFY_TOKEN=your_verify_token
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-key
CLAUDE_DEFAULT_MODEL=claude-sonnet-4-20250514

# Google (Gemini)
GEMINI_API_KEY=your_gemini_key
GEMINI_DEFAULT_MODEL=gemini-2.5-flash

# Instagram / Meta Graph API
INSTAGRAM_ACCESS_TOKEN=your_ig_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_ig_account_id

# AWS S3 / Cloudflare R2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=marketing-assets
S3_ENDPOINT_URL=

# Razorpay (Phase 2)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Observability
OTLP_GRPC_ENDPOINT=
LOG_LEVEL=DEBUG
